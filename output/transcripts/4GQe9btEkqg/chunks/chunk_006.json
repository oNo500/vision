      "text": "楼下便利店的买的。",
      "text_normalized": "",
      "confidence": 0.98,
      "chunk_id": 6
    },
    {
      "idx": 11,
      "start": 7222.55,
      "end": 7225.05,
      "speaker": "guest",
      "text": "对，因为我从门这买，所以我们没有关注过它。",
      "text_normalized": "",
