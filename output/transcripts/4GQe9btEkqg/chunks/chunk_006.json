      "end": 7215.65,
      "speaker": "host",
      "text": "是六块五。",
      "text_normalized": "",
      "confidence": 0.98,
      "chunk_id": 6
    },
    {
      "idx": 8,
      "start": 7216.05,
      "end": 7219.65,
      "speaker": "host",
      "text": "这个比另外一个品牌的那个呃旗间的牛奶贵个五毛钱。",
      "text_normalized": "",
      "confidence": 0.97,
      "chunk_id": 6
    },
    {
      "idx": 9,
      "start": 7220.05,
      "end": 7220.85,
      "speaker": "host",
      "text": "你们有没有注意吧？",
