      "text": "他们说交易额多了，你直播间的这个人数就会高。",
      "text_normalized": "",
      "confidence": 0.98,
      "chunk_id": 6
    },
    {
      "idx": 29,
      "start": 7330.65,
      "end": 7333.35,
      "speaker": "host",
      "text": "我们还卖过一个星期左右的化妆品。",
      "text_normalized": "",
      "confidence": 0.97,
      "chunk_id": 6
    },
    {
      "idx": 30,
