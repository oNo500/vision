      "text_normalized": "",
      "confidence": 0.98,
      "chunk_id": 6
    },
    {
      "idx": 3,
      "start": 7197.05,
      "end": 7197.35,
      "speaker": "host",
      "text": "啊。",
      "text_normalized": "",
      "confidence": 0.95,
      "chunk_id": 6
    },
    {
      "idx": 4,
      "start": 7206.05,
      "end": 7209.45,
      "speaker": "host",
      "text": "牛奶酸奶一瓶三块多，应该是挺便宜的，坦诚来说。",
      "text_normalized": "",
      "confidence": 0.98,
      "chunk_id": 6
    },
    {
      "idx": 5,
      "start": 7210.05,
      "end": 7214.05,
      "speaker": "host",
      "text": "因为正常如果在楼下便利店买这一盒是六块五。",
      "text_normalized": "",
      "confidence": 0.98,
      "chunk_id": 6
    },
    {
      "idx": 6,
      "start": 7214.15,
      "end": 7214.65,
