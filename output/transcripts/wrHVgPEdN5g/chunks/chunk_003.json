      "chunk_id": 3
    },
    {
      "idx": 181,
      "start": 3598.062,
      "end": 3598.115,
      "speaker": "host",
      "text": "就是把枸杞、红枣、黄色的冰糖，还有茶叶，还有一些芝麻好像。",
