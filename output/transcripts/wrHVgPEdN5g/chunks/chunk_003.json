      "text": "对不起，对不起。",
      "text_normalized": "",
      "confidence": 0.98,
      "chunk_id": 3
    },
    {
      "idx": 223,
      "start": 3599.455,
      "end": 3599.5,
      "speaker": "host",
      "text": "我们那天晚上再给大家讲到这个大话西游的时候，就提到了周星驰年轻时候的遗憾和错过。",
      "text_normalized": "",
      "confidence": 0.97,
      "chunk_id": 3
    },
    {
      "idx": 224,
      "start": 3599.5,
      "end": 3599.52,
