      "confidence": 0.97,
      "chunk_id": 3
    },
    {
      "idx": 183,
      "start": 3598.144,
      "end": 3598.154,
      "speaker": "host",
      "text": "我特别喜欢。",
      "text_normalized": "",
      "confidence": 0.98,
      "chunk_id": 3
    },
    {
      "idx": 184,
      "start": 3598.165,
      "end": 3598.177,
      "speaker": "host",
      "text": "叫二毛手抓是吧？",
      "text_normalized": "",
      "confidence": 0.98,
      "chunk_id": 3
    },
    {
      "idx": 185,
      "start": 3598.177,
