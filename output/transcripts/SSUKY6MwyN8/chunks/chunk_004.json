      "text": "广州大量的滞留。",
      "text_normalized": "",
      "confidence": 0.98,
      "chunk_id": 4
    },
    {
      "idx": 116,
      "start": 5231.0,
      "end": 5235.0,
      "speaker": "host",
      "text": "没有办法，都是扛着被子要回家的。",
      "text_normalized": "",
