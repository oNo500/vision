      "speaker": "host",
      "text": "没有办法。",
      "text_normalized": "",
      "confidence": 0.98,
      "chunk_id": 4
    },
    {
      "idx": 120,
      "start": 5244.0,
      "end": 5247.0,
      "speaker": "host",
      "text": "越来越多的人涌入了广州火车站。",
