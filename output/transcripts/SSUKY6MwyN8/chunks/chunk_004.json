    },
    {
      "idx": 117,
      "start": 5236.0,
      "end": 5237.0,
      "speaker": "host",
      "text": "这叫务工人员。",
      "text_normalized": "",
      "confidence": 0.98,
      "chunk_id": 4
    },
    {
      "idx": 118,
      "start": 5237.0,
      "end": 5242.0,
      "speaker": "host",
      "text": "回家这种大的人口迁徙全世界只有在中国能找到，一年拉其实亿人的往返啊。",
      "text_normalized": "",
      "confidence": 0.97,
      "chunk_id": 4
    },
    {
      "idx": 119,
      "start": 5243.0,
