      "chunk_id": 4
    },
    {
      "idx": 109,
      "start": 5217.0,
      "end": 5219.0,
      "speaker": "host",
      "text": "那是多事之秋啊，那叫eventful。",
      "text_normalized": "",
      "confidence": 0.97,
      "chunk_id": 4
    },
    {
      "idx": 110,
      "start": 5219.0,
      "end": 5221.0,
      "speaker": "host",
      "text": "Yes。",
      "text_normalized": "",
      "confidence": 0.98,
      "chunk_id": 4
    },
    {
      "idx": 111,
      "start": 5221.0,
      "end": 5223.0,
      "speaker": "host",
      "text": "Event就大的事件。",
      "text_normalized": "",
      "confidence": 0.98,
      "chunk_id": 4
    },
    {
      "idx": 112,
      "start": 5223.0,
      "end": 5225.0,
      "speaker": "host",
      "text": "Eventful就是发生了很多大的事件。",
      "text_normalized": "",
      "confidence": 0.97,
      "chunk_id": 4
    },
    {
      "idx": 113,
      "start": 5225.0,
      "end": 5227.0,
      "speaker": "host",
      "text": "Eventful year。",
      "text_normalized": "",
      "confidence": 0.98,
      "chunk_id": 4
    },
    {
      "idx": 114,
      "start": 5227.0,
      "end": 5229.0,
      "speaker": "host",
      "text": "所以2008年是was an eventful year。",
      "text_normalized": "",
      "confidence": 0.97,
      "chunk_id": 4
    },
    {
      "idx": 115,
      "start": 5229.0,
      "end": 5231.0,
