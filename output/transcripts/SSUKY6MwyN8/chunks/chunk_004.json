      "text_normalized": "",
      "confidence": 0.9,
      "chunk_id": 4
    },
    {
      "idx": 104,
      "start": 5207.0,
      "end": 5208.0,
      "speaker": "host",
      "text": "你知道那个事情是吧？",
      "text_normalized": "",
      "confidence": 0.98,
      "chunk_id": 4
    },
    {
      "idx": 105,
      "start": 5208.0,
      "end": 5209.0,
      "speaker": "guest",
      "text": "08年的广州。",
      "text_normalized": "",
      "confidence": 0.9,
      "chunk_id": 4
    },
    {
      "idx": 106,
      "start": 5209.0,
      "end": 5210.0,
      "speaker": "host",
      "text": "听过这个事是吧？",
      "text_normalized": "",
      "confidence": 0.98,
      "chunk_id": 4
    },
    {
      "idx": 107,
      "start": 5211.0,
      "end": 5215.0,
      "speaker": "host",
      "text": "08年的广州的火车站滞留了有十几万人，整整滞留了六天。",
      "text_normalized": "",
      "confidence": 0.97,
      "chunk_id": 4
    },
    {
      "idx": 108,
      "start": 5215.0,
      "end": 5217.0,
      "speaker": "host",
      "text": "为什么呢？因为那年正好逢着南方动雨。",
      "text_normalized": "",
