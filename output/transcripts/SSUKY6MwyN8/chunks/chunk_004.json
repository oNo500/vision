      "confidence": 0.97,
      "chunk_id": 4
    },
    {
      "idx": 130,
      "start": 5279.0,
      "end": 5281.0,
      "speaker": "host",
      "text": "而是扎扎实实的开始做自己该做的事情。",
      "text_normalized": "",
      "confidence": 0.98,
      "chunk_id": 4
    },
    {
      "idx": 131,
      "start": 5281.0,
