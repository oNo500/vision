      "confidence": 0.97,
      "chunk_id": 4
    },
    {
      "idx": 122,
      "start": 5250.0,
      "end": 5252.0,
      "speaker": "host",
      "text": "然后呢不断地往火车上冲去。",
      "text_normalized": "",
      "confidence": 0.98,
      "chunk_id": 4
    },
    {
      "idx": 123,
      "start": 5252.0,
      "end": 5253.0,
      "speaker": "host",
      "text": "但是能理解。",
      "text_normalized": "",
