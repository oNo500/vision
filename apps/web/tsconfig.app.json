{
  "extends": "@infra-x/typescript-config/tsconfig.nextjs.json",
  "compilerOptions": {
    "incremental": true,
    "paths": {
      "@/*": ["./src/*"],
      "@workspace/ui/*": ["../../packages/ui/src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": [
    "node_modules",
    "__tests__",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "oxlint.config.ts"
  ]
}
