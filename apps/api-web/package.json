    "better-auth": "^1.5.5",
    "dotenv": "^17.3.1",
    "drizzle-orm": "0.45.2",
    "lucide-react": "^1.0.0",
    "next": "16.2.3",
    "next-themes": "^0.4.6",
    "pg": "8.20.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
